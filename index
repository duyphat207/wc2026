                            </div>
                            <div onclick="advanceTeam('${roundKey}', ${index}, 2)" class="flex items-center justify-between p-2 rounded-xl border ${t2Class} cursor-pointer transition-all duration-300">
                                <div class="flex items-center gap-2 truncate"><span class="text-lg">${t2 ? t2.flag : '❓'}</span><span class="text-xs truncate">${t2 ? t2.name : 'Chờ cặp đấu'}</span></div>
                                ${t2Won ? '<span class="text-[9px] text-gold font-bold bg-gold/20 px-1.5 py-0.5 rounded uppercase">Thắng</span>' : ''}
                            </div>
                        </div>
                    </div>`;
            }

            document.getElementById("left-r32-container").innerHTML = knockoutState.r32.slice(0, 8).map((m, i) => matchHtml(m, 'r32', i)).join('');
            document.getElementById("left-r16-container").innerHTML = knockoutState.r16.slice(0, 4).map((m, i) => matchHtml(m, 'r16', i)).join('');
