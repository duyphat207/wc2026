        function renderKnockoutBracket() {
            function matchHtml(match, roundKey, index) {
                const t1 = match.team1, t2 = match.team2;
                const t1Won = match.winner && t1 && match.winner.code === t1.code;
                const t2Won = match.winner && t2 && match.winner.code === t2.code;
                const t1Class = t1Won ? 'bg-gold/10 border-gold text-white font-extrabold shadow-sm' : 'hover:bg-gray-800/20 border-gray-800 text-gray-400 hover:text-white';
                const t2Class = t2Won ? 'bg-gold/10 border-gold text-white font-extrabold shadow-sm' : 'hover:bg-gray-800/20 border-gray-800 text-gray-400 hover:text-white';
                return `
