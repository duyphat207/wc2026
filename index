        }

        /* =========================================================================
           4. CHỈNH SỬA KẾT QUẢ (manual)
        ========================================================================= */
        function editStat(gId, code, field, value) {
            const team = groupsState[gId].find(t => t.code === code);
            if (!team) return;
            team[field] = Math.max(0, parseInt(value) || 0);
            // Không re-sort khi đang gõ để tránh nhảy dòng; áp dụng khi tắt edit / bấm cập nhật.
        }

        function toggleEditMode() {
            editMode = !editMode;
            document.getElementById("mode-indicator").innerText = editMode ? "Sửa" : "Xem";
            document.getElementById("mode-indicator").className = editMode ? "font-bold text-blue-300 text-sm" : "font-bold text-accentgreen text-sm";
            document.getElementById("edit-banner").classList.toggle("hidden", !editMode);
            document.getElementById("edit-btn").innerHTML = editMode
                ? '<i class="fa-solid fa-check"></i> Cập Nhật BXH'
                : '<i class="fa-solid fa-pen-to-square"></i> Nhập / Sửa Kết Quả';
            if (editMode) {
                switchTab('group-stage');
                renderGroups();
            } else {
                recomputeAll();
                addCommentary("✅ Đã cập nhật bảng xếp hạng và phân nhánh theo kết quả mới.");
            }
        }

        function recomputeAll() {
            renderGroups();
            calculateAdvancingTeams();
            updateAnalysis();
            saveState();
        }

        /* =========================================================================
           5. MÔ PHỎNG (dùng rating)
        ========================================================================= */
        function autoSimulateEntireKnockout() {
            ['r32', 'r16', 'qf', 'sf'].forEach(simulatePhase);
            simulateMatch(knockoutState.thirdPlace);
            simulateMatch(knockoutState.final);
            syncSubsequentKnockoutRounds();
            renderKnockoutBracket();
            updateAnalysis();
            saveState();
            if (knockoutState.champion) triggerChampionConfetti(knockoutState.champion);
            switchTab('knockout-bracket');
        }
        function simulatePhase(roundKey) {
            knockoutState[roundKey].forEach(simulateMatch);
            syncSubsequentKnockoutRounds();
        }
        function simulateMatch(match) {
            if (!match.team1 || !match.team2) return;
            const chanceT1 = (match.team1.rating / (match.team1.rating + match.team2.rating)) * 100;
            match.winner = (Math.random() * 100) <= chanceT1 ? match.team1 : match.team2;
        }
        function triggerChampionConfetti(team) {
            confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 }, colors: ['#D4AF37', '#ffffff', '#1E3A8A', '#10B981'] });
            addCommentary(`🏆 <strong>${team.flag} ${team.name}</strong> vô địch World Cup 2026!`);
        }

        /* =========================================================================
           6. PHÂN TÍCH
        ========================================================================= */
        function updateAnalysis() {
            const cand = {};
            const add = (team, w) => { if (!team) return; if (!cand[team.code]) cand[team.code] = { team, points: 0 }; cand[team.code].points += w; };
            knockoutState.r32.forEach(m => { add(m.team1, 1); add(m.team2, 1); add(m.winner, 2); });
            knockoutState.r16.forEach(m => add(m.winner, 4));
            knockoutState.qf.forEach(m => add(m.winner, 8));
            knockoutState.sf.forEach(m => add(m.winner, 16));
            if (knockoutState.champion) add(knockoutState.champion, 32);

            const sorted = Object.values(cand).sort((a, b) => b.points - a.points).slice(0, 3);
            const container = document.getElementById("top-candidates-list");
            if (!sorted.length) { container.innerHTML = `<div class="text-xs text-gray-500 italic">Bấm "Giả Lập Nhánh" để phân tích.</div>`; return; }
            container.innerHTML = sorted.map((c, i) => {
                let badge = "bg-gray-800 text-gray-300";
                if (i === 0) badge = "bg-gold/20 text-gold border border-gold/40";
                if (i === 1) badge = "bg-slate-300/20 text-slate-200";
                if (i === 2) badge = "bg-amber-700/20 text-amber-500";
                return `<div class="flex items-center justify-between p-2 rounded-lg bg-darkbg/40">
                    <div class="flex items-center gap-2"><span class="w-5 h-5 flex items-center justify-center text-xs font-bold rounded-full ${badge}">${i + 1}</span><span>${c.team.flag} ${c.team.name}</span></div>
                    <span class="text-xs font-bold text-gray-400">Sức mạnh: ${c.points}</span></div>`;
            }).join('');
        }

        function addCommentary(message) {
            const list = document.getElementById("commentary-list");
            if (!list) return;
            const el = document.createElement("div");
            el.className = "p-3 bg-darkbg/50 rounded-xl border-l-4 border-gold text-xs text-gray-300";
            el.innerHTML = message;
            list.insertBefore(el, list.firstChild);
        }

        /* =========================================================================
           7. LƯU TRỮ (localStorage). Bọc try/catch để không vỡ ở môi trường chặn storage.
        ========================================================================= */
        function saveState() {
            try {
                const data = {
                    groups: {},
                    ko: {
                        r32: knockoutState.r32.map(m => m.winner ? m.winner.code : null),
                        r16: knockoutState.r16.map(m => m.winner ? m.winner.code : null),
                        qf: knockoutState.qf.map(m => m.winner ? m.winner.code : null),
                        sf: knockoutState.sf.map(m => m.winner ? m.winner.code : null),
                        final: knockoutState.final.winner ? knockoutState.final.winner.code : null,
                        thirdPlace: knockoutState.thirdPlace.winner ? knockoutState.thirdPlace.winner.code : null
                    }
                };
                for (let gId of GROUP_IDS) data.groups[gId] = groupsState[gId].map(t => ({ code: t.code, w: t.w, d: t.d, l: t.l, gf: t.gf, ga: t.ga }));
                localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            } catch (e) { /* storage bị chặn (vd preview) — bỏ qua, vẫn chạy bình thường */ }
        }

        function loadState() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (!raw) return false;
                const data = JSON.parse(raw);
                if (data.groups) {
                    for (let gId of GROUP_IDS) {
                        if (!data.groups[gId]) continue;
                        data.groups[gId].forEach(saved => {
                            const team = groupsState[gId].find(t => t.code === saved.code);
                            if (team) Object.assign(team, { w: saved.w, d: saved.d, l: saved.l, gf: saved.gf, ga: saved.ga });
                        });
                    }
                }
                window.__savedKO = data.ko || null;
                return true;
            } catch (e) { return false; }
        }

        function reapplyKnockoutWinners(ko) {
            if (!ko) return;
            const setByCode = (match, code) => {
                if (!code) return;
                if (match.team1 && match.team1.code === code) match.winner = match.team1;
                else if (match.team2 && match.team2.code === code) match.winner = match.team2;
            };
            knockoutState.r32.forEach((m, i) => setByCode(m, ko.r32 && ko.r32[i]));
            syncSubsequentKnockoutRounds();
            knockoutState.r16.forEach((m, i) => setByCode(m, ko.r16 && ko.r16[i]));
            syncSubsequentKnockoutRounds();
            knockoutState.qf.forEach((m, i) => setByCode(m, ko.qf && ko.qf[i]));
            syncSubsequentKnockoutRounds();
            knockoutState.sf.forEach((m, i) => setByCode(m, ko.sf && ko.sf[i]));
            syncSubsequentKnockoutRounds();
            setByCode(knockoutState.final, ko.final);
            setByCode(knockoutState.thirdPlace, ko.thirdPlace);
            syncSubsequentKnockoutRounds();
            renderKnockoutBracket();
        }

        /* =========================================================================
           8. HOOK LIVE — cô lập. Khi có nguồn đã xác minh (schema + CORS) thì điền vào đây.
              Hiện tại chưa cấu hình → báo rõ thay vì fail âm thầm.
        ========================================================================= */
        async function fetchLiveData() {
            // ────────────────────────────────────────────────────────────────────
            // CÁCH WIRE (khi bạn đã có nguồn):
            //   1. const res = await fetch(YOUR_ENDPOINT);  // hoặc qua Vercel proxy /api/standings
            //   2. const json = await res.json();
            //   3. Map về groupsState[gId] = [{code, w, d, l, gf, ga}, ...] theo schema của bạn.
            //   4. Gọi recomputeAll();
            // Nếu gặp CORS: tạo file api/standings.js (Vercel Serverless) làm proxy giấu key.
            // ────────────────────────────────────────────────────────────────────
            const CONFIGURED = false; // ← đổi thành true sau khi điền logic ở trên
            if (!CONFIGURED) {
                toast("Chưa cấu hình nguồn Live. Dùng \"Nhập / Sửa Kết Quả\" để cập nhật tay (chi tiết trong code, hàm fetchLiveData).");
                return;
            }
            // ví dụ khung xử lý (đang tắt):
            // try { ... } catch (e) { toast("Không lấy được dữ liệu Live: " + e.message); }
        }

        function toast(msg) {
            const wrap = document.getElementById("toast-wrap");
            const el = document.createElement("div");
            el.className = "toast";
            el.innerHTML = `<i class="fa-solid fa-circle-info text-gold mr-1"></i> ${msg}`;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 6000);
        }

        /* =========================================================================
           9. ĐIỀU HƯỚNG & RESET
        ========================================================================= */
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => { el.classList.add('hidden'); el.classList.remove('block'); });
            document.getElementById(`content-${tabId}`).classList.remove('hidden');
            document.getElementById(`content-${tabId}`).classList.add('block');
            ['group-stage', 'third-places', 'knockout-bracket', 'statistics'].forEach(t => {
                const btn = document.getElementById(`tab-${t}`);
                if (!btn) return;
                btn.className = (t === tabId)
                    ? "flex-1 text-center py-3 px-4 rounded-xl text-sm font-bold bg-gold text-darkbg shadow-lg tab-transition whitespace-nowrap"
                    : "flex-1 text-center py-3 px-4 rounded-xl text-sm font-semibold text-gray-400 hover:text-white transition-all duration-300 tab-transition whitespace-nowrap";
            });
        }

        function scrollToRound(sectionId) {
            const el = document.getElementById(sectionId);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        }

        function resetAll() {
            knockoutState = buildEmptyKnockout();
            calculateAdvancingTeams();
            updateAnalysis();
            saveState();
            addCommentary("🔄 Đã đặt lại toàn bộ nhánh knockout.");
            toast("Đã đặt lại nhánh đấu.");
        }

        /* =========================================================================
           10. KHỞI TẠO
        ========================================================================= */
        window.onload = function () {
            initGroups();
            const hadSave = loadState();
            renderGroups();
            calculateAdvancingTeams();
            if (hadSave && window.__savedKO) reapplyKnockoutWinners(window.__savedKO);
            updateAnalysis();
        };
    </script>
</body>
