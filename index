<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Cup 2026 — Simulator & Bracket Predictor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        gold: '#D4AF37', goldhover: '#AA820A', sportred: '#E50914',
                        sportblue: '#1A365D', darkbg: '#0B0F19', panelbg: '#161F30', accentgreen: '#00FF66'
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'bounce-slow': 'bounce 2s infinite',
                    }
                }
            }
        }
    </script>
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0B0F19; }
        ::-webkit-scrollbar-thumb { background: #1F2937; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #374151; }
        .glow-gold { box-shadow: 0 0 20px rgba(212, 175, 55, 0.3); }
        .tab-transition { transition: all 0.3s ease-in-out; }
        .bracket-col { display: flex; flex-direction: column; justify-content: space-around; height: 1050px; }
        .stat-input {
            width: 38px; background: #0B0F19; border: 1px solid #374151; border-radius: 6px;
            text-align: center; color: #fff; font-size: 12px; padding: 2px 0;
        }
        .stat-input:focus { outline: none; border-color: #D4AF37; }
        /* Toast */
        #toast-wrap { position: fixed; bottom: 20px; right: 20px; z-index: 60; display: flex; flex-direction: column; gap: 8px; }
        .toast {
            background: #161F30; border: 1px solid #374151; border-left: 4px solid #D4AF37;
            color: #e5e7eb; font-size: 12px; padding: 10px 14px; border-radius: 10px;
            max-width: 340px; box-shadow: 0 8px 24px rgba(0,0,0,.4); animation: slidein .25s ease;
        }
        @keyframes slidein { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    </style>
</head>
<body class="bg-darkbg text-gray-100 font-sans min-h-screen selection:bg-gold selection:text-darkbg overflow-x-hidden">

    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-blue-900/20 via-transparent to-transparent pointer-events-none"></div>
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl pointer-events-none animate-pulse-slow"></div>
    <div class="absolute top-40 -right-40 w-96 h-96 bg-gold/10 rounded-full blur-3xl pointer-events-none animate-pulse-slow"></div>

    <header class="sticky top-0 z-50 bg-darkbg/85 backdrop-blur-md border-b border-gray-800/80 px-4 py-3">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-tr from-gold to-yellow-300 rounded-lg flex items-center justify-center shadow-lg transform rotate-3">
                    <i class="fa-solid fa-trophy text-darkbg text-xl"></i>
                </div>
                <div>
                    <h1 class="text-xl font-black tracking-wider uppercase bg-clip-text text-transparent bg-gradient-to-r from-white via-gray-200 to-gold">
                        World Cup 2026
                    </h1>
                    <p class="text-[10px] text-gray-400 font-medium tracking-widest uppercase">Bộ Mô Phỏng & Dự Đoán Nhánh Đấu</p>
                </div>
            </div>

            <div class="flex items-center gap-6 text-xs bg-panelbg/60 px-4 py-2 rounded-xl border border-gray-800">
                <div class="text-center">
                    <span class="text-gray-400 block">Số Đội</span>
                    <span class="font-bold text-white text-sm">48</span>
                </div>
                <div class="h-6 w-[1px] bg-gray-800"></div>
                <div class="text-center">
                    <span class="text-gray-400 block">Số Bảng</span>
                    <span class="font-bold text-white text-sm">12</span>
                </div>
                <div class="h-6 w-[1px] bg-gray-800"></div>
                <div class="text-center">
                    <span class="text-gray-400 block">Chế Độ</span>
                    <span id="mode-indicator" class="font-bold text-accentgreen text-sm">Xem</span>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <button onclick="toggleEditMode()" id="edit-btn" class="bg-blue-500/20 hover:bg-blue-500/30 text-blue-300 border border-blue-500/30 font-bold text-xs px-3 py-2 rounded-lg transition flex items-center gap-1.5 shadow-md">
                    <i class="fa-solid fa-pen-to-square"></i> Nhập / Sửa Kết Quả
                </button>
                <button onclick="fetchLiveData()" class="bg-accentgreen/15 hover:bg-accentgreen/25 text-accentgreen border border-accentgreen/30 font-bold text-xs px-3 py-2 rounded-lg transition flex items-center gap-1.5 shadow-md">
                    <i class="fa-solid fa-rotate"></i> Lấy Live
                </button>
                <button onclick="autoSimulateEntireKnockout()" class="bg-gold hover:bg-yellow-500 text-darkbg font-extrabold text-xs px-3 py-2 rounded-lg transition flex items-center gap-1 shadow-md">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Giả Lập Nhánh
                </button>
                <button onclick="resetAll()" class="bg-gray-800 hover:bg-gray-700 text-gray-300 font-bold text-xs px-3 py-2 rounded-lg transition border border-gray-700 flex items-center gap-1">
                    <i class="fa-solid fa-rotate-left"></i> Đặt Lại
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-6 relative z-10">
        <div class="bg-gradient-to-r from-blue-950/80 to-purple-950/40 rounded-3xl p-6 md:p-8 border border-blue-900/40 shadow-2xl mb-8 flex flex-col md:flex-row items-center justify-between gap-6 overflow-hidden relative">
            <div class="space-y-3 z-10 max-w-2xl">
                <span class="bg-blue-500/20 text-blue-300 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-widest border border-blue-500/30">
                    Manual-first · Bracket Predictor
                </span>
                <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight">
                    Mô Phỏng <span class="bg-clip-text text-transparent bg-gradient-to-r from-gold to-yellow-300">FIFA World Cup 2026</span>
                </h2>
                <p class="text-gray-300 text-sm md:text-base">
                    Bấm <span class="text-blue-300 font-bold">Nhập / Sửa Kết Quả</span> để gõ thành tích từng đội (Thắng / Hòa / Thua / Bàn thắng / Bàn thua). Bảng xếp hạng, danh sách đội hạng 3 đi tiếp và toàn bộ nhánh knockout sẽ tự tính theo đúng luật FIFA. Mọi thay đổi được lưu tự động trên trình duyệt.
                </p>
            </div>
            <div class="relative w-36 h-36 flex-shrink-0 flex items-center justify-center">
                <div class="absolute inset-0 bg-gold/10 rounded-full blur-2xl animate-pulse-slow"></div>
                <div class="text-gold text-6xl animate-bounce-slow drop-shadow-[0_0_25px_rgba(212,175,55,0.6)]">
                    <i class="fa-solid fa-futbol"></i>
                </div>
            </div>
        </div>

        <div class="flex space-x-2 border-b border-gray-800 mb-8 p-1 bg-panelbg/40 rounded-2xl max-w-2xl mx-auto md:mx-0 overflow-x-auto">
            <button onclick="switchTab('group-stage')" id="tab-group-stage" class="flex-1 text-center py-3 px-4 rounded-xl text-sm font-bold bg-gold text-darkbg shadow-lg tab-transition whitespace-nowrap">
                <i class="fa-solid fa-list-ol mr-1.5"></i> Vòng Bảng
            </button>
            <button onclick="switchTab('third-places')" id="tab-third-places" class="flex-1 text-center py-3 px-4 rounded-xl text-sm font-semibold text-gray-400 hover:text-white transition-all duration-300 tab-transition whitespace-nowrap">
                <i class="fa-solid fa-award mr-1.5"></i> Đội Hạng 3
            </button>
            <button onclick="switchTab('knockout-bracket')" id="tab-knockout-bracket" class="flex-1 text-center py-3 px-4 rounded-xl text-sm font-semibold text-gray-400 hover:text-white transition-all duration-300 tab-transition whitespace-nowrap">
                <i class="fa-solid fa-sitemap mr-1.5"></i> Nhánh Knockout
            </button>
            <button onclick="switchTab('statistics')" id="tab-statistics" class="flex-1 text-center py-3 px-4 rounded-xl text-sm font-semibold text-gray-400 hover:text-white transition-all duration-300 tab-transition whitespace-nowrap">
                <i class="fa-solid fa-newspaper mr-1.5"></i> Phân Tích
            </button>
        </div>

        <!-- TAB 1: GROUP STAGE -->
        <div id="content-group-stage" class="tab-content block">
            <div id="edit-banner" class="hidden mb-5 bg-blue-950/40 border border-blue-800/50 rounded-2xl px-4 py-3 text-xs text-blue-200 flex items-center gap-2">
                <i class="fa-solid fa-circle-info"></i>
                Đang ở chế độ chỉnh sửa. Gõ số T (thắng) / H (hòa) / B (thua) / BT (bàn thắng) / BB (bàn bại) cho từng đội. Bấm <span class="font-bold text-white">"Cập nhật BXH"</span> hoặc tắt chế độ sửa để áp dụng.
            </div>
            <div id="groups-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        </div>

        <!-- TAB 2: THIRD PLACES -->
        <div id="content-third-places" class="tab-content hidden">
            <div class="bg-panelbg/60 p-6 rounded-3xl border border-gray-800/80 shadow-xl mb-8">
                <div class="border-b border-gray-800 pb-4 mb-6">
                    <h3 class="text-xl font-black text-white flex items-center gap-2">
                        <i class="fa-solid fa-award text-gold"></i> Bảng Xếp Hạng Đội Hạng 3
                    </h3>
                    <p class="text-xs text-gray-400 mt-1">
                        Theo thể thức 48 đội, <span class="text-accentgreen font-bold">8 đội hạng 3 tốt nhất</span> trong 12 bảng giành vé vào Vòng 1/32.
                    </p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-[11px] text-gray-400 uppercase tracking-widest border-b border-gray-800">
                                <th class="pb-3 pl-4 w-16 text-center">Hạng</th>
                                <th class="pb-3 w-16 text-center">Bảng</th>
                                <th class="pb-3">Đội Tuyển</th>
                                <th class="pb-3 w-20 text-center">ST</th>
                                <th class="pb-3 w-24 text-center">HS</th>
                                <th class="pb-3 w-20 text-center">BT</th>
                                <th class="pb-3 w-24 text-center">Điểm</th>
                                <th class="pb-3 pr-4 w-36 text-center">Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody id="third-places-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TAB 3: KNOCKOUT BRACKET -->
        <div id="content-knockout-bracket" class="tab-content hidden">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6 bg-panelbg/60 p-4 rounded-2xl border border-gray-800">
                <div>
                    <h3 class="text-lg font-bold text-white flex items-center gap-2">
                        <i class="fa-solid fa-network-wired text-gold"></i> Nhánh Đấu Đối Xứng (Knockout Tree)
                    </h3>
                    <p class="text-xs text-gray-400 mt-1">Bấm vào một đội để cho họ đi tiếp. Hai nhánh Trái – Phải hội tụ về Chung Kết ở trung tâm.</p>
                </div>
                <div class="flex items-center gap-2 overflow-x-auto pb-2 lg:pb-0">
                    <button onclick="scrollToRound('left-r32-section')" class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-xs font-semibold rounded-lg text-gray-200 transition-all flex-shrink-0">
                        <i class="fa-solid fa-chevron-left mr-1"></i> Nhánh Trái
                    </button>
                    <button onclick="scrollToRound('center-final-section')" class="px-3 py-1.5 bg-gold/20 hover:bg-gold/30 text-xs font-bold rounded-lg text-gold border border-gold/30 transition-all flex-shrink-0">
                         Chung Kết
                    </button>
                    <button onclick="scrollToRound('right-r32-section')" class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-xs font-semibold rounded-lg text-gray-200 transition-all flex-shrink-0">
                        Nhánh Phải <i class="fa-solid fa-chevron-right ml-1"></i>
                    </button>
                </div>
            </div>

            <div class="overflow-x-auto pb-8 pt-4">
                <div class="min-w-[2100px] flex items-stretch gap-6 relative px-4 justify-between">
                    <div class="flex items-stretch gap-6 flex-1 justify-start">
                        <div id="left-r32-section" class="w-[240px] flex-shrink-0">
                            <h4 class="text-center font-extrabold text-xs text-gray-400 bg-gray-900/60 py-2 rounded-xl border border-gray-800/80 mb-3 uppercase tracking-wider">Vòng 1/32 (Trái)</h4>
                            <div id="left-r32-container" class="bracket-col"></div>
                        </div>
                        <div id="left-r16-section" class="w-[240px] flex-shrink-0">
                            <h4 class="text-center font-extrabold text-xs text-blue-400 bg-blue-950/40 py-2 rounded-xl border border-blue-900/30 mb-3 uppercase tracking-wider">Vòng 1/16 (Trái)</h4>
                            <div id="left-r16-container" class="bracket-col"></div>
                        </div>
                        <div id="left-qf-section" class="w-[240px] flex-shrink-0">
                            <h4 class="text-center font-extrabold text-xs text-indigo-400 bg-indigo-950/40 py-2 rounded-xl border border-indigo-900/30 mb-3 uppercase tracking-wider">Tứ Kết (Trái)</h4>
                            <div id="left-qf-container" class="bracket-col"></div>
                        </div>
                        <div id="left-sf-section" class="w-[240px] flex-shrink-0">
                            <h4 class="text-center font-extrabold text-xs text-purple-400 bg-purple-950/40 py-2 rounded-xl border border-purple-900/30 mb-3 uppercase tracking-wider">Bán Kết (Trái)</h4>
                            <div id="left-sf-container" class="bracket-col"></div>
                        </div>
                    </div>

                    <div id="center-final-section" class="w-[340px] flex-shrink-0 flex flex-col justify-center gap-8 bg-gradient-to-b from-gold/5 via-panelbg/20 to-transparent p-4 rounded-3xl border border-gold/15">
