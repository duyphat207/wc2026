        /* Dữ liệu mẫu (placeholder) — điểm/HS để minh hoạ. Bạn ghi đè bằng "Nhập / Sửa Kết Quả". */
        const SEED_GROUPS = {
            "A": [["MEX",3,9,6],["RSA",3,4,-1],["KOR",3,3,-1],["CZE",3,1,-4]],
            "B": [["SUI",3,7,4],["CAN",3,4,5],["BIH",3,4,-1],["QAT",3,1,-8]],
            "C": [["BRA",3,7,6],["MAR",3,7,3],["SCO",3,3,-3],["HAI",3,0,-6]],
            "D": [["USA",2,6,5],["AUS",2,3,0],["PAR",2,3,-2],["TUR",2,0,-3]],
            "E": [["GER",3,6,6],["CIV",3,6,2],["ECU",3,4,0],["CUW",3,1,-8]],
            "F": [["NED",3,7,6],["JPN",3,5,4],["SWE",3,4,0],["TUN",3,0,-10]],
            "G": [["EGY",2,4,2],["IRN",2,2,0],["BEL",2,2,0],["NZL",2,1,-2]],
            "H": [["ESP",2,4,4],["URU",2,2,0],["CPV",2,2,0],["KSA",2,1,-4]],
            "I": [["FRA",2,6,5],["NOR",2,6,4],["SEN",2,0,-3],["IRQ",2,0,-6]],
            "J": [["ARG",2,6,5],["AUT",2,3,0],["ALG",2,3,-2],["JOR",2,0,-3]],
            "K": [["COL",2,6,3],["POR",2,4,5],["COD",2,1,-1],["UZB",2,0,-7]],
            "L": [["ENG",2,4,2],["GHA",2,4,1],["CRO",2,3,-1],["PAN",2,0,-2]]
        };

        const GROUP_IDS = ["A","B","C","D","E","F","G","H","I","J","K","L"];
        const STORAGE_KEY = "wc2026_state_v1";

        let groupsState = {};
        let editMode = false;
        let knockoutState = buildEmptyKnockout();

        function buildEmptyKnockout() {
            return {
                r32: Array(16).fill(null).map((_, i) => ({ id: i, team1: null, team2: null, winner: null })),
                r16: Array(8).fill(null).map((_, i) => ({ id: i, team1: null, team2: null, winner: null })),
                qf: Array(4).fill(null).map((_, i) => ({ id: i, team1: null, team2: null, winner: null })),
                sf: Array(2).fill(null).map((_, i) => ({ id: i, team1: null, team2: null, winner: null })),
                final: { id: 0, team1: null, team2: null, winner: null },
                thirdPlace: { id: 0, team1: null, team2: null, winner: null },
                champion: null
            };
        }

        /* Suy ra W/D/L và GF/GA hợp lệ từ {played, points, gd} của dữ liệu mẫu. */
        function synthesizeStats(played, points, gdv) {
            let w = 0, d = 0, l = 0;
            for (let ww = Math.min(played, Math.floor(points / 3)); ww >= 0; ww--) {
                const dd = points - 3 * ww;
                if (dd >= 0 && ww + dd <= played) { w = ww; d = dd; l = played - ww - dd; break; }
            }
            let gf = Math.max(0, Math.round(4 + gdv / 2));
            let ga = gf - gdv;
            if (ga < 0) { gf -= ga; ga = 0; }
            return { w, d, l, gf, ga };
        }

        function initGroups() {
            for (let gId of GROUP_IDS) {
                groupsState[gId] = SEED_GROUPS[gId].map(([code, played, points, gd]) => {
                    const base = TEAMS_DATA[code];
                    const s = synthesizeStats(played, points, gd);
                    return { code, name: base.name, flag: base.flag, rating: base.rating,
                             w: s.w, d: s.d, l: s.l, gf: s.gf, ga: s.ga };
                });
            }
        }

        /* ----- Helpers tính toán theo luật ----- */
        const played = t => t.w + t.d + t.l;
        const points = t => t.w * 3 + t.d;
        const gd = t => t.gf - t.ga;

        /* Tiêu chí FIFA: Điểm → Hiệu số → Bàn thắng ghi → (tên, để ổn định).
           ⚠️ Luật đầy đủ còn có đối đầu trực tiếp + fair-play, cần dữ liệu cấp trận
           nên không áp dụng được ở chế độ nhập tổng hợp này. */
        function compareTeams(a, b) {
            if (points(b) !== points(a)) return points(b) - points(a);
            if (gd(b) !== gd(a)) return gd(b) - gd(a);
            if (b.gf !== a.gf) return b.gf - a.gf;
            return a.name.localeCompare(b.name);
        }

        /* =========================================================================
           2. PHÂN BỔ ĐỘI HẠNG 3 (backtracking). 
           ⚠️ CẦN ĐỐI CHIẾU: các danh sách allowed dưới đây phải khớp 100% với bảng
              tổ hợp chính thức của FIFA (sơ đồ image_ac9724.png). Sai 1 dòng là lệch nhánh.
        ========================================================================= */
        function solveThirdPlaceMatching(top8Thirds) {
            const slots = [
                { id: "E_slot", allowed: ["A","B","C","D","F"] },
                { id: "I_slot", allowed: ["C","D","F","G","H"] },
                { id: "A_slot", allowed: ["C","E","F","H","I"] },
                { id: "L_slot", allowed: ["E","H","I","J","K"] },
                { id: "D_slot", allowed: ["B","E","F","I","J"] },
                { id: "G_slot", allowed: ["A","E","H","I","J"] },
                { id: "B_slot", allowed: ["E","F","G","I","J"] },
                { id: "K_slot", allowed: ["D","E","I","J","L"] }
            ];
            let assignment = {}, used = new Set();
            function backtrack(i) {
                if (i === slots.length) return true;
                for (let j = 0; j < top8Thirds.length; j++) {
                    if (used.has(j)) continue;
                    if (slots[i].allowed.includes(top8Thirds[j].sourceGroup)) {
                        assignment[slots[i].id] = top8Thirds[j]; used.add(j);
                        if (backtrack(i + 1)) return true;
                        used.delete(j); delete assignment[slots[i].id];
                    }
                }
                return false;
            }
            if (backtrack(0)) return assignment;
            // Fallback: gán an toàn để không tạo undefined
            let fb = {}, fbUsed = new Set();
            slots.forEach(slot => {
                let idx = top8Thirds.findIndex((t, k) => !fbUsed.has(k) && slot.allowed.includes(t.sourceGroup));
                if (idx === -1) idx = top8Thirds.findIndex((t, k) => !fbUsed.has(k));
                if (idx !== -1) { fb[slot.id] = top8Thirds[idx]; fbUsed.add(idx); }
            });
            return fb;
        }

        function calculateAdvancingTeams() {
            const winners = {}, runnersUp = {}, thirds = [];
            GROUP_IDS.forEach(gId => {
                const sorted = [...groupsState[gId]].sort(compareTeams);
                winners[gId] = sorted[0];
                runnersUp[gId] = sorted[1];
                thirds.push({ ...sorted[2], sourceGroup: gId });
            });

            thirds.sort((a, b) => {
                if (points(b) !== points(a)) return points(b) - points(a);
                if (gd(b) !== gd(a)) return gd(b) - gd(a);
                if (b.gf !== a.gf) return b.gf - a.gf;
                return a.name.localeCompare(b.name);
            });
            const top8 = thirds.slice(0, 8);

            renderThirdTable(thirds);

            const m = solveThirdPlaceMatching(top8);
            const W = winners, RU = runnersUp;

            const r32 = [
                { team1: RU["A"], team2: RU["B"] },
                { team1: W["E"],  team2: m["E_slot"] },
                { team1: W["F"],  team2: RU["C"] },
                { team1: W["C"],  team2: RU["F"] },
                { team1: W["I"],  team2: m["I_slot"] },
                { team1: RU["E"], team2: RU["I"] },
                { team1: W["A"],  team2: m["A_slot"] },
                { team1: W["L"],  team2: m["L_slot"] },
                { team1: W["D"],  team2: m["D_slot"] },
                { team1: W["G"],  team2: m["G_slot"] },
                { team1: RU["K"], team2: RU["L"] },
                { team1: W["H"],  team2: RU["J"] },
                { team1: W["B"],  team2: m["B_slot"] },
                { team1: W["J"],  team2: RU["H"] },
                { team1: W["K"],  team2: m["K_slot"] },
                { team1: RU["D"], team2: RU["G"] }
            ];

            r32.forEach((pair, i) => {
                knockoutState.r32[i].team1 = pair.team1 || null;
                knockoutState.r32[i].team2 = pair.team2 || null;
                validateMatchWinner(knockoutState.r32[i]);
            });

            syncSubsequentKnockoutRounds();
            renderKnockoutBracket();
        }

        function syncSubsequentKnockoutRounds() {
            for (let i = 0; i < 8; i++) {
                knockoutState.r16[i].team1 = knockoutState.r32[i * 2].winner;
                knockoutState.r16[i].team2 = knockoutState.r32[i * 2 + 1].winner;
                validateMatchWinner(knockoutState.r16[i]);
            }
            for (let i = 0; i < 4; i++) {
                knockoutState.qf[i].team1 = knockoutState.r16[i * 2].winner;
                knockoutState.qf[i].team2 = knockoutState.r16[i * 2 + 1].winner;
                validateMatchWinner(knockoutState.qf[i]);
            }
            knockoutState.sf[0].team1 = knockoutState.qf[0].winner;
            knockoutState.sf[0].team2 = knockoutState.qf[1].winner;
            validateMatchWinner(knockoutState.sf[0]);
            knockoutState.sf[1].team1 = knockoutState.qf[2].winner;
            knockoutState.sf[1].team2 = knockoutState.qf[3].winner;
            validateMatchWinner(knockoutState.sf[1]);

            knockoutState.final.team1 = knockoutState.sf[0].winner;
            knockoutState.final.team2 = knockoutState.sf[1].winner;
            validateMatchWinner(knockoutState.final);

            knockoutState.thirdPlace.team1 = getLoser(knockoutState.sf[0]);
            knockoutState.thirdPlace.team2 = getLoser(knockoutState.sf[1]);
            validateMatchWinner(knockoutState.thirdPlace);

            knockoutState.champion = knockoutState.final.winner || null;
        }

        function getLoser(match) {
            if (!match.winner) return null;
            if (match.team1 && match.winner.code === match.team1.code) return match.team2;
            if (match.team2 && match.winner.code === match.team2.code) return match.team1;
            return null;
        }

        function validateMatchWinner(match) {
            if (!match.winner) return;
            const w = match.winner.code;
            const t1 = match.team1 ? match.team1.code : null;
            const t2 = match.team2 ? match.team2.code : null;
            if (w !== t1 && w !== t2) match.winner = null;
        }

        function advanceTeam(roundKey, matchIndex, teamNum) {
            const match = roundKey === 'final' ? knockoutState.final
                        : roundKey === 'thirdPlace' ? knockoutState.thirdPlace
                        : knockoutState[roundKey][matchIndex];
            const target = teamNum === 1 ? match.team1 : match.team2;
            if (!target) return;
            match.winner = target;
            if (roundKey === 'final') triggerChampionConfetti(target);
            syncSubsequentKnockoutRounds();
            renderKnockoutBracket();
            updateAnalysis();
            saveState();
        }

